# RunwaySurfer proxy backend — configuration

# Provider AI: 'mock' (default, demo, nessuna chiamata reale) | 'anthropic'
AI_PROVIDER=mock

# Necessaria solo con AI_PROVIDER=anthropic. Custodita sul server, mai nell'estensione.
ANTHROPIC_API_KEY=

# Porta HTTP del proxy (esporre via reverse proxy con TLS).
PORT=8787

# Origine consentita per il CORS. In produzione: l'origin dell'estensione
# (chrome-extension://<id>). Per la demo va bene '*'.
ALLOWED_ORIGIN=*
